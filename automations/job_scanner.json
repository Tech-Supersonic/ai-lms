    },
    {
      "parameters": {
        "jsCode": "return $input.all();"
      },
      "id": "7dbf386b-134e-4f63-a103-307b86dcf9bf",
      "name": "Merge All Sources",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -304,
        -256
      ]
    },
    {
      "parameters": {
        "jsCode": "const postings = $input.all();\nconst skillKeywords = [\n  'python', 'javascript', 'typescript', 'node.js', 'fastapi',\n  'postgresql', 'docker', 'kubernetes', 'terraform', 'aws', 'gcp',\n  'langchain', 'langgraph', 'n8n', 'mcp', 'rag', 'vector database',\n  'pinecone', 'redis', 'graphql', 'rest api', 'ci/cd', 'github actions',\n  'ollama', 'openai', 'anthropic', 'llm', 'machine learning', 'mlops'\n];\n\nconst counts = {};\nconst sources = {};\nconst titlesForSkill = {};\n\nfor (const item of postings) {\n  const text = ((item.json.description || '') + ' ' + (item.json.title || '')).toLowerCase();\n  const src  = item.json.source || 'unknown';\n  const title = (item.json.title || '').trim();\n\n  for (const skill of skillKeywords) {\n    if (text.includes(skill)) {\n      counts[skill] = (counts[skill] || 0) + 1;\n\n      if (!sources[skill]) sources[skill] = new Set();\n      sources[skill].add(src);\n\n      if (!titlesForSkill[skill]) titlesForSkill[skill] = [];\n      if (title && titlesForSkill[skill].length < 3) {\n        titlesForSkill[skill].push(title);\n      }\n    }\n  }\n}\n\nreturn Object.entries(counts)\n  .filter(([_, count]) => count > 1)\n  .map(([skill, frequency]) => ({\n    json: {\n      skill_name: skill,\n      frequency,\n      source: Array.from(sources[skill]).join(', '),\n      role_matched: 'ai/backend developer',\n      captured_on: new Date().toISOString().split('T')[0],\n      reviewed: false,\n      _jobsworth_title: titlesForSkill[skill]?.[0] || 'software developer',\n      _jobsworth_description: skill\n    }\n  }));"
      },
      "id": "12d1bc73-c4a3-468c-865f-7e998a0b786a",
      "name": "Extract Skill Keywords",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -80,
        -256
      ]
    },
