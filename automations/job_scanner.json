      "parameters": {
        "jsCode": "const inserted = $input.all().length;\nconst withSalary = $input.all().filter(i => i.json.estimated_salary !== null).length;\nreturn [{\n  json: {\n    message: `Job scan complete. ${inserted} skills saved. ${withSalary} have salary estimates.`\n  }\n}];"
      },
