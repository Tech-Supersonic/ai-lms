        -256
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst results = raw.results || [];\nreturn results.map(job => ({\n  json: {\n    title: job.title || '',\n    description: job.description || '',\n    source: 'adzuna'\n  }\n}));"
      },
